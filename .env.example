# Application
APP_NAME=AI Sandbox
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=info

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aisandbox
APP_DB=sandbox_app
MLFLOW_DB=mlflow
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sandbox_app

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_PORT=5000

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET_NAME=sandbox
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# JWT (Phase 5)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Backend
BACKEND_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
FRONTEND_PORT=5173

# Experiment defaults
DEFAULT_RANDOM_SEED=42

{
  "$schema": "https://opencode.ai/config.json",
  // Project-level OpenCode defaults for consistent behavior in this repository.
  "instructions": ["AGENTS.md"],
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask"
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      "node_modules/**"
    ]
  }
}
